# Local Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://nfc:nfc@localhost:5432/nfc

# Shopify (Step 2) — leave blank until then
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=http://localhost:3000

# Anthropic (Step 5)
ANTHROPIC_API_KEY=

# CDN base URL for the tap page (Step 3)
TAP_PAGE_CDN_URL=http://localhost:3001

# Random secret for signing session cookies — generate with: openssl rand -hex 32
COOKIE_SECRET=dev-secret-change-in-prod
